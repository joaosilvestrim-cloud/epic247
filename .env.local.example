# Supabase — copie para .env.local e preencha com as credenciais do seu projeto
# (Dashboard do Supabase > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Usada apenas no servidor (rota /api/lead) para gravar leads ignorando RLS.
# NUNCA exponha esta chave no client. Não use o prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# Senha do painel administrativo (/admin). Use algo forte.
ADMIN_PASSWORD=defina-uma-senha-forte

# E-mail (Resend) — para enviar o relatório em PDF após o quiz.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=EPIC247 <contato@seudominio.com.br>

# Rastreamento
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=
NEXT_PUBLIC_GA4_ID=
